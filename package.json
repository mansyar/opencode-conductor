{
  "name": "opencode-conductor-plugin",
  "version": "1.33.0",
  "description": "Conductor plugin for OpenCode",
  "type": "module",
  "repository": "derekbar90/opencode-conductor",
  "keywords": [
    "opencode",
    "plugin",
    "conductor",
    "agent",
    "sisyphus"
  ],
  "author": "Derek Barrera",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/derekbar90/opencode-conductor/issues"
  },
  "homepage": "https://github.com/derekbar90/opencode-conductor#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "legacy"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "shx rm -rf dist && tsc && npm run copy-assets",
    "copy-assets": "shx mkdir -p dist/templates && shx cp -r src/templates/* dist/templates/ && shx mkdir -p dist/prompts && shx cp -r src/prompts/* dist/prompts/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.0.223"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "4.1.5",
    "semantic-release": "^24.2.1",
    "shx": "^0.4.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.16"
  },
  "release": {
    "branches": [
      "main"
    ],
    "repositoryUrl": "https://github.com/derekbar90/opencode-conductor",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
